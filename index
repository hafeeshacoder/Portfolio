
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Fathima Hafeesha P | AI, Data Analytics & Full Stack Portfolio</title>
  <meta name="description" content="Portfolio of Fathima Hafeesha P, a B.Sc Computer Science Artificial Intelligence student with projects in AI, data analytics, computer vision, full stack SaaS development, and web development." />

  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet" />

  <style>
    :root {
      --primary: #4f8cff;
      --primary-light: #8fb7ff;
      --primary-glow: rgba(79,140,255,0.16);
      --accent: #18d5a7;
      --accent2: #f4b95e;
      --bg: #060914;
      --bg-card: #0d1424;
      --bg-surface: #101827;
      --border: rgba(143,183,255,0.18);
      --text: #eef4ff;
      --muted: #9badc8;
      --font: 'Manrope', sans-serif;
      --display: 'Space Grotesk', sans-serif;
      --mono: 'Fira Code', monospace;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font); background: var(--bg); color: var(--text); overflow-x: hidden;
      background-image:
        linear-gradient(rgba(143,183,255,0.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(143,183,255,0.035) 1px, transparent 1px),
        linear-gradient(180deg, #060914 0%, #08101e 45%, #060914 100%);
      background-size: 52px 52px, 52px 52px, 100% 100%;
    }

    /* SCROLLBAR */
    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--primary); border-radius: 10px; }

    /* NAVBAR */
    .navbar {
      background: rgba(6,9,20,0.86) !important;
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
      padding: 0.6rem 0;
      transition: box-shadow 0.3s;
    }
    .navbar.scrolled { box-shadow: 0 4px 28px rgba(0,0,0,0.5); }
    .navbar-brand {
      font-family: var(--display);
      font-size: 0.95rem;
      color: var(--primary-light) !important;
      letter-spacing: 0.02em;
    }
    .nav-link {
      color: var(--muted) !important;
      font-size: 0.84rem;
      font-weight: 500;
      padding: 0.4rem 0.9rem !important;
      border-radius: 6px;
      transition: color 0.2s, background 0.2s;
    }
    .nav-link:hover, .nav-link.active { color: var(--primary-light) !important; background: var(--primary-glow); }
    .btn-nav-cta {
      background: linear-gradient(135deg, var(--primary), var(--accent));
      color: #fff !important;
      font-weight: 700;
      font-size: 0.82rem;
      padding: 0.42rem 1.2rem !important;
      border-radius: 6px;
      transition: opacity 0.2s, transform 0.2s;
    }
    .btn-nav-cta:hover { opacity: 0.85; transform: translateY(-1px); }

    /* HERO */
    #hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding-top: 80px;
      position: relative;
      overflow: hidden;
      background:
        radial-gradient(ellipse 70% 60% at 74% 30%, rgba(79,140,255,0.13) 0%, transparent 65%),
        radial-gradient(ellipse 50% 42% at 12% 78%, rgba(24,213,167,0.08) 0%, transparent 62%),
        var(--bg);
    }
    #hero::before {
      content: '';
      position: absolute; inset: 0;
      background-image: radial-gradient(rgba(124,58,237,0.08) 1.2px, transparent 1.2px);
      background-size: 36px 36px;
      pointer-events: none;
    }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(124,58,237,0.12);
      border: 1px solid rgba(124,58,237,0.28);
      color: var(--primary-light);
      font-size: 0.7rem; font-weight: 700;
      padding: 5px 14px; border-radius: 999px;
      letter-spacing: 0.1em; text-transform: uppercase;
      margin-bottom: 1.4rem;
    }
    .hero-badge .dot { width: 7px; height: 7px; background: var(--accent); border-radius: 50%; animation: blink 2s infinite; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.25} }

    .hero-name {
      font-family: var(--display); font-size: clamp(2.7rem, 6vw, 5rem); font-weight: 700;
      line-height: 0.95; margin-bottom: 1rem; letter-spacing: 0;
      text-wrap: balance;
    }
    .hero-role {
      font-size: clamp(1.3rem, 3.5vw, 2rem); font-weight: 800;
      background: linear-gradient(135deg, var(--primary-light), var(--accent));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text; margin-bottom: 1.2rem; line-height: 1.15;
    }
    .hero-desc { font-size: 1rem; color: var(--muted); max-width: 620px; line-height: 1.85; margin-bottom: 1.2rem; }
    .hero-chips { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 2rem; }
    .hero-chip {
      display: inline-flex; align-items: center; gap: 7px; color: var(--text);
      background: rgba(255,255,255,0.045); border: 1px solid rgba(143,183,255,0.18);
      border-radius: 999px; padding: 7px 12px; font-size: 0.75rem; font-weight: 700;
    }
    .hero-chip i { color: var(--accent); }

    .btn-cta {
      background: linear-gradient(135deg, var(--primary), var(--accent));
      color: #fff; font-weight: 700; font-size: 0.9rem;
      padding: 12px 28px; border-radius: 8px; border: none;
      text-decoration: none; display: inline-block;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .btn-cta:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(79,140,255,0.36); color: #fff; }
    .btn-ghost {
      background: transparent; color: var(--text); font-weight: 600;
      font-size: 0.9rem; padding: 11px 28px; border-radius: 8px;
      border: 1px solid var(--border); text-decoration: none;
      display: inline-block; transition: border-color 0.2s, color 0.2s;
    }
    .btn-ghost:hover { border-color: var(--primary-light); color: var(--primary-light); }

    /* STAT CARDS */
    .stat-mini {
      text-align: left; min-width: 112px; padding: 0.9rem 1rem;
      background: rgba(13,20,36,0.72); border: 1px solid var(--border); border-radius: 12px;
    }
    .stat-mini .num { font-family: var(--display); font-size: 2rem; font-weight: 700; color: var(--primary-light); line-height: 1; }
    .stat-mini .lbl { font-size: 0.68rem; color: var(--muted); margin-top: 5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; }

    /* AI BRAIN VISUAL */
    .brain-card {
      background: linear-gradient(180deg, rgba(13,20,36,0.92), rgba(13,20,36,0.76));
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 1.7rem;
      position: relative;
      overflow: hidden;
      box-shadow: 0 24px 80px rgba(0,0,0,0.28);
    }
    .brain-card::before {
      content: '🧠';
      position: absolute; right: -10px; bottom: -10px;
      font-size: 6rem; opacity: 0.06;
    }
    .brain-title { font-family: var(--display); font-size: 0.86rem; color: var(--primary-light); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 1rem; }
    .ai-chip {
      display: inline-flex; align-items: center; gap: 6px;
      background: rgba(124,58,237,0.1); border: 1px solid rgba(124,58,237,0.22);
      color: var(--primary-light); font-size: 0.75rem; font-weight: 600;
      padding: 5px 12px; border-radius: 6px; margin: 4px;
    }
    .ai-chip.green { background: rgba(6,214,160,0.1); border-color: rgba(6,214,160,0.22); color: var(--accent); }
    .ai-chip.amber { background: rgba(245,158,11,0.1); border-color: rgba(245,158,11,0.22); color: var(--accent2); }
    .brain-bar-wrap { margin-top: 1.2rem; }
    .brain-bar-row { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
    .brain-bar-label { font-size: 0.72rem; color: var(--muted); min-width: 80px; }
    .brain-bar { flex: 1; height: 4px; background: rgba(255,255,255,0.06); border-radius: 4px; overflow: hidden; }
    .brain-bar-fill { height: 100%; border-radius: 4px; background: linear-gradient(90deg, var(--primary), var(--accent)); width: 0; transition: width 1.4s cubic-bezier(.4,0,.2,1); }

    /* SECTIONS */
    section { padding: 90px 0; position: relative; }
    .sec-eye { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--primary-light); margin-bottom: 0.4rem; }
    .sec-title { font-family: var(--display); font-size: clamp(1.8rem, 4vw, 2.5rem); font-weight: 700; margin-bottom: 0.7rem; letter-spacing: 0; }
    .sec-sub { color: var(--muted); font-size: 0.92rem; max-width: 620px; line-height: 1.7; }

    /* SKILLS */
    #skills { background: var(--bg-surface); }
    .skill-pill {
      display: flex; align-items: center; gap: 10px;
      background: linear-gradient(180deg, rgba(13,20,36,0.96), rgba(13,20,36,0.76));
      border: 1px solid var(--border);
      border-radius: 12px; padding: 0.95rem 1rem; min-height: 118px;
      transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
    }
    .skill-pill:hover { border-color: rgba(24,213,167,0.38); transform: translateY(-3px); box-shadow: 0 16px 42px rgba(0,0,0,0.22); }
    .skill-emoji { font-size: 1.2rem; width: 36px; height: 36px; text-align: center; display: grid; place-items: center; border-radius: 10px; background: rgba(143,183,255,0.08); }
    .skill-text .sn { font-size: 0.85rem; font-weight: 700; }
    .skill-text .sl { font-size: 0.67rem; color: var(--muted); }
    .sk-bar { height: 3px; background: rgba(124,58,237,0.1); border-radius: 3px; margin-top: 6px; }
    .sk-fill { height: 100%; border-radius: 3px; background: linear-gradient(90deg, var(--primary), var(--accent)); width: 0; transition: width 1.3s cubic-bezier(.4,0,.2,1); }
    .skill-proof { font-size: 0.64rem; color: var(--accent); margin-top: 5px; line-height: 1.45; }
    .stack-strip {
      background: linear-gradient(135deg, rgba(124,58,237,0.09), rgba(6,214,160,0.05));
      border: 1px solid var(--border); border-radius: 14px; padding: 1.1rem;
    }
    .stack-title { font-size: 0.82rem; font-weight: 800; margin-bottom: 0.75rem; color: var(--primary-light); }

    /* CATEGORY BADGES */
    .cat-badge {
      font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em;
      text-transform: uppercase; padding: 4px 12px; border-radius: 999px; border: 1px solid;
      display: inline-block; margin-bottom: 1.2rem;
    }
    .cat-ai { background: rgba(124,58,237,0.1); border-color: rgba(124,58,237,0.3); color: var(--primary-light); }
    .cat-web { background: rgba(6,214,160,0.1); border-color: rgba(6,214,160,0.3); color: var(--accent); }
    .cat-core { background: rgba(245,158,11,0.1); border-color: rgba(245,158,11,0.3); color: var(--accent2); }

    /* PROJECTS */
    .proj-card {
      background: linear-gradient(180deg, rgba(13,20,36,0.96), rgba(13,20,36,0.82)); border: 1px solid var(--border);
      border-radius: 14px; overflow: hidden;
      transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
      height: 100%; display: flex; flex-direction: column;
    }
    .proj-card:hover { border-color: rgba(24,213,167,0.38); transform: translateY(-5px); box-shadow: 0 22px 60px rgba(0,0,0,0.26); }
    .proj-top {
      background: linear-gradient(135deg, rgba(124,58,237,0.09), rgba(6,214,160,0.05));
      padding: 1.3rem; display: flex; justify-content: space-between; align-items: flex-start;
    }
    .proj-emoji { font-size: 2rem; }
    .proj-links a { color: var(--muted); font-size: 1rem; margin-left: 10px; text-decoration: none; transition: color 0.2s; }
    .proj-links a:hover { color: var(--primary-light); }
    .proj-body { padding: 1.1rem; flex: 1; }
    .proj-title { font-size: 0.95rem; font-weight: 800; margin-bottom: 0.4rem; }
    .proj-desc { font-size: 0.8rem; color: var(--muted); line-height: 1.75; }
    .proj-footer { padding: 0 1.1rem 1.1rem; display: flex; flex-wrap: wrap; gap: 5px; }
    .tag {
      background: rgba(124,58,237,0.08); border: 1px solid rgba(124,58,237,0.18);
      color: var(--primary-light); font-family: var(--mono);
      font-size: 0.65rem; padding: 3px 9px; border-radius: 999px;
    }
    .tag.green { background: rgba(6,214,160,0.08); border-color: rgba(6,214,160,0.2); color: var(--accent); }
    .fresher-badge {
      display: inline-flex; align-items: center; gap: 5px;
      background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.25);
      color: var(--accent2); font-size: 0.65rem; font-weight: 700;
      padding: 2px 9px; border-radius: 999px; margin-bottom: 6px;
    }

    /* INTERNSHIP */
    #internship { background: var(--bg); }
    .intern-card {
      background: linear-gradient(180deg, rgba(13,20,36,0.96), rgba(13,20,36,0.78)); border: 1px solid var(--border);
      border-radius: 14px; padding: 1.5rem; height: 100%;
      transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
    }
    .intern-card:hover { border-color: rgba(24,213,167,0.38); transform: translateY(-3px); box-shadow: 0 18px 50px rgba(0,0,0,0.24); }
    .intern-role { font-size: 1rem; font-weight: 800; margin-bottom: 0.35rem; }
    .intern-company { color: var(--primary-light); font-size: 0.85rem; font-weight: 700; margin-bottom: 0.6rem; }
    .intern-duration { color: var(--accent); font-size: 0.75rem; font-weight: 700; margin-bottom: 1rem; }
    .intern-list { color: var(--muted); font-size: 0.8rem; line-height: 1.75; padding-left: 1.1rem; margin-bottom: 0; }

    /* CERTIFICATIONS */
    #certifications { background: var(--bg-surface); }
    .cert-card {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: 12px; padding: 1.3rem;
      display: flex; align-items: flex-start; gap: 14px;
      transition: border-color 0.25s, transform 0.25s;
    }
    .cert-card:hover { border-color: rgba(124,58,237,0.4); transform: translateY(-3px); }
    .cert-icon {
      width: 44px; height: 44px; border-radius: 10px;
      background: var(--primary-glow); display: flex; align-items: center;
      justify-content: center; font-size: 1.3rem; flex-shrink: 0;
    }
    .cert-name { font-size: 0.9rem; font-weight: 700; }
    .cert-org { font-size: 0.75rem; color: var(--primary-light); margin-top: 3px; }
    .cert-year { font-size: 0.7rem; color: var(--muted); margin-top: 4px; }
    .cert-grid-card {
      background: linear-gradient(135deg, rgba(124,58,237,0.1), rgba(6,214,160,0.05));
      border: 1px solid var(--border); border-radius: 14px; padding: 1.4rem;
      height: 100%; position: relative; overflow: hidden;
    }
    .cert-grid-card::after {
      content: '✓'; position: absolute; right: 18px; bottom: -20px;
      font-size: 6rem; color: rgba(6,214,160,0.08); font-weight: 900;
    }
    .cert-count { font-size: 2.4rem; font-weight: 900; color: var(--primary-light); line-height: 1; }
    .cert-note { color: var(--muted); font-size: 0.82rem; line-height: 1.7; margin-top: 0.8rem; position: relative; }
    .cert-badge-cloud { display: flex; flex-wrap: wrap; gap: 10px; }
    .cert-provider {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: 999px; padding: 9px 14px; color: var(--text);
      font-size: 0.78rem; font-weight: 700;
      transition: border-color 0.25s, color 0.25s, transform 0.25s;
    }
    .cert-provider:hover { border-color: rgba(6,214,160,0.45); color: var(--accent); transform: translateY(-2px); }
    .cert-provider i { color: var(--primary-light); }

    /* EDUCATION */
    .edu-card {
      background: linear-gradient(180deg, rgba(13,20,36,0.96), rgba(13,20,36,0.78)); border: 1px solid var(--border);
      border-radius: 14px; padding: 1.6rem;
      transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
      position: relative; overflow: hidden;
    }
    .edu-card:hover { border-color: rgba(24,213,167,0.38); transform: translateY(-3px); box-shadow: 0 18px 50px rgba(0,0,0,0.22); }
    .edu-card::after { content: '🎓'; position: absolute; right: 10px; bottom: 10px; font-size: 3rem; opacity: 0.07; }
    .edu-degree { font-size: 1.05rem; font-weight: 800; }
    .edu-spec { font-size: 0.85rem; color: var(--primary-light); font-weight: 600; margin-top: 4px; }
    .edu-school { font-size: 0.8rem; color: var(--muted); margin-top: 3px; }
    .edu-year { font-size: 0.75rem; color: var(--muted); margin-top: 8px; }
    .edu-gpa {
      display: inline-block; background: rgba(6,214,160,0.1);
      border: 1px solid rgba(6,214,160,0.22); color: var(--accent);
      font-size: 0.72rem; font-weight: 700; padding: 3px 12px;
      border-radius: 999px; margin-top: 10px;
    }

    /* CONTACT */
    .contact-wrap {
      background: linear-gradient(135deg, rgba(124,58,237,0.08), rgba(6,214,160,0.05));
      border: 1px solid var(--border); border-radius: 18px;
      padding: 3.5rem 2rem; text-align: center; position: relative; overflow: hidden;
      box-shadow: 0 24px 80px rgba(0,0,0,0.25);
    }
    .contact-wrap::before {
      content: '';
      position: absolute; inset: 0;
      background-image: radial-gradient(rgba(124,58,237,0.07) 1px, transparent 1px);
      background-size: 30px 30px; pointer-events: none;
    }
    .contact-title { font-family: var(--display); font-size: 2rem; font-weight: 700; margin-bottom: 0.6rem; position: relative; }
    .contact-sub { color: var(--muted); font-size: 0.92rem; margin-bottom: 2rem; position: relative; }
    .c-pill {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--bg-card); border: 1px solid var(--border);
      color: var(--text); padding: 10px 20px; border-radius: 8px;
      font-size: 0.85rem; font-weight: 600; text-decoration: none;
      transition: border-color 0.2s, color 0.2s, transform 0.2s; position: relative;
    }
    .c-pill:hover { border-color: var(--primary-light); color: var(--primary-light); transform: translateY(-2px); }

    /* FOOTER */
    footer {
      text-align: center; padding: 1.5rem;
      color: var(--muted); font-family: var(--mono); font-size: 0.76rem;
      border-top: 1px solid var(--border);
    }

    /* SCROLL TOP */
    #topBtn {
      position: fixed; bottom: 1.8rem; right: 1.8rem;
      width: 42px; height: 42px; background: var(--primary);
      color: #fff; border: none; border-radius: 50%; font-size: 1.1rem;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; opacity: 0; pointer-events: none;
      transition: opacity 0.3s, transform 0.2s; z-index: 999;
      box-shadow: 0 4px 18px rgba(124,58,237,0.45);
    }
    #topBtn.show { opacity: 1; pointer-events: auto; }
    #topBtn:hover { transform: translateY(-3px); }

    /* ANIMATIONS */
    .fade-up { opacity: 0; transform: translateY(26px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .fade-up.in { opacity: 1; transform: translateY(0); }

    @media (max-width: 768px) {
      section { padding: 60px 0; }
      .contact-wrap { padding: 2rem 1rem; }
      .stat-mini { flex: 1 1 30%; min-width: 90px; padding: 0.8rem; }
    }
  </style>
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg fixed-top" id="navbar">
  <div class="container">
    <a class="navbar-brand" href="#hero">&lt;FathimaHafeesha /&gt;</a>
    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navLinks">
      <i class="bi bi-list" style="color:var(--text);font-size:1.5rem"></i>
    </button>
    <div class="collapse navbar-collapse" id="navLinks">
      <ul class="navbar-nav ms-auto align-items-lg-center gap-1">
        <li class="nav-item"><a class="nav-link" href="#skills">Skills</a></li>
        <li class="nav-item"><a class="nav-link" href="#internship">Internship</a></li>
        <li class="nav-item"><a class="nav-link" href="#projects">Projects</a></li>
        <li class="nav-item"><a class="nav-link" href="#certifications">Certifications</a></li>
        <li class="nav-item"><a class="nav-link" href="#education">Education</a></li>
        <li class="nav-item ms-lg-2"><a class="nav-link btn-nav-cta" href="#contact">Contact</a></li>
      </ul>
    </div>
  </div>
</nav>

<!-- HERO -->
<section id="hero">
  <div class="container">
    <div class="row align-items-center gy-5">

      <!-- Left -->
      <div class="col-lg-7 fade-up">
        <div class="hero-badge"><span class="dot"></span>Fresher · Open to Opportunities</div>
        <h1 class="hero-name">Fathima Hafeesha P</h1>
        <p class="hero-desc">
          AI-focused Computer Science student building practical solutions across machine learning, data analytics, computer vision, full stack SaaS development, and accessible web experiences.
        </p>
        <div class="hero-chips">
          <span class="hero-chip"><i class="bi bi-stars"></i>AI & ML Projects</span>
